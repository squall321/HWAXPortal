# ─────────────────────────────────────────────────────────────────────────────
# HWAX Portal — environment template.
# Copy to backend/.env for local dev. NEVER commit real secrets.
# Dev defaults are chosen so the full mock-SSO loop runs with ZERO external deps.
# ─────────────────────────────────────────────────────────────────────────────

# App  (dev ports are deliberately uncommon to avoid collisions on shared boxes)
APP_ENV=dev                          # dev | prod
# public_base_url = the origin BROWSERS reach the portal at. In dev that is the Vite proxy
# (5283), not the uvicorn bind port (8723) — so cookies + SAML Destination share one origin.
PUBLIC_BASE_URL=http://localhost:5283
FRONTEND_URL=http://localhost:5283    # SPA origin (dev: vite). Used for post-login redirect.

# Session cookie / CSRF
SESSION_SECRET=change-me-dev-only     # signs/encrypts session cookie state
COOKIE_SECURE=false                   # dev=false (http). prod MUST be true (https)
COOKIE_SAMESITE=lax                   # lax works with SAML POST-back top-level nav

# ── Auth provider selection (THE go-live switch) ─────────────────────────────
AUTH_PROVIDER=mock                    # mock | saml   (flip to saml for real AD)

# Mock provider (dev only): a fake AD user returned without real SAML
MOCK_USER_EMAIL=hong.gildong@samsung.com
MOCK_USER_NAME=Hong Gil Dong
MOCK_USER_GROUPS=portal-admin,mes-user

# SAML SP (used when AUTH_PROVIDER=saml). Paths relative to backend/.
# ACS/SLS URLs are DERIVED from PUBLIC_BASE_URL (no need to set them).
SAML_SP_ENTITY_ID=https://hwax.sec.samsung.net/sp
SAML_SP_CERT_PATH=config/saml/sp.crt
SAML_SP_KEY_PATH=secrets/saml/sp.key
SAML_IDP_METADATA_PATH=config/saml/dev/mock_idp_metadata.xml   # DEV: mock IdP
# SAML_IDP_METADATA_URL=https://ad.sec.samsung.net/.../metadata # PROD: real AD
# Attribute mapping (which SAML attr -> which Principal field). Adjust at go-live.
SAML_ATTR_EMAIL=email
SAML_ATTR_NAME=displayName
SAML_ATTR_GROUPS=memberOf

# ── Downstream JWT issuance (RS256, verified by downstream via JWKS) ──────────
JWT_ISSUER=https://hwax.sec.samsung.net
JWT_KEYS_DIR=secrets/jwt              # <kid>.key (private) + <kid>.pub (public)
JWT_ACTIVE_KID=dev-1
JWT_SESSION_TTL=900                   # portal session access token (s)
JWT_REFRESH_TTL=28800                 # portal refresh token (s) = 8h
JWT_LAUNCH_TTL=90                     # downstream launch token (s) — short!

# Token store (refresh revocation + jti replay). Pilot = sqlite; prod -> redis.
TOKEN_STORE_PATH=secrets/token_store.sqlite

# Catalog
CATALOG_PATH=config/systems.yaml

# ── Mail (hwax@samsung.com automated send) ───────────────────────────────────
MAIL_BACKEND=console                  # console | smtp | graph
MAIL_FROM=hwax@samsung.com
# smtp backend
SMTP_HOST=
SMTP_PORT=587
SMTP_USERNAME=
SMTP_PASSWORD=
SMTP_STARTTLS=true
# graph backend (Microsoft 365) — recommended for prod
GRAPH_TENANT_ID=
GRAPH_CLIENT_ID=
GRAPH_CLIENT_SECRET=
