# HWAXAgentServer vLLM 주소 .env 블록 — 대상: <HWAXAgentServer>/.env (없는 키만 추가됨)
# vLLM 주소는 playbook §8 원칙대로 config/env 로 잡는다. agent-server 는 ReportArchive 가 이미 쓰는
# LLM 설정을 '그대로' 상속한다 — apply 시점에 형제 ReportArchive/.env 의 LLM_BASE_URL·LLM_MODEL 을
# 읽어 아래 마커를 치환한다(둘 다 OpenAI 호환 /v1 이라 값이 그대로 맞는다).
#   · cae00(운영): RA 가 상암 프로덕션 LLM(B300 openai 백엔드, 예: http://10.198.143.137:10000/v1,
#     model GLM-5-2)으로 설정돼 있으면 agent-server 도 동일하게 상속.
#   · dev: RA 가 mock(LLM_ 미설정)이면 이 키들은 건너뛰어 agent-server 기본값(로컬 vLLM
#     http://127.0.0.1:8000/v1, qwen2.5-7b-dev)을 쓴다. 이 PC vLLM 으로 강제 테스트하려면 대상
#     .env 에 VLLM_BASE_URL=http://192.168.1.100:8000/v1 을 직접 넣으면 된다(기존 키는 보존됨).
VLLM_BASE_URL=@FROM_RA:LLM_BASE_URL@
VLLM_MODEL=@FROM_RA:LLM_MODEL@
VLLM_API_KEY=@FROM_RA:LLM_API_KEY@
# 사내 프록시 박스(cae00)에서 필수: http(s)_proxy 가 설정된 프로세스는 상암 등 내부 IP 요청도
# 프록시로 흘려 Connection error 가 난다. httpx(agent)가 존중하는 NO_PROXY 로 내부 목적지 예외.
NO_PROXY=10.198.143.137,127.0.0.1,localhost
no_proxy=10.198.143.137,127.0.0.1,localhost

# --- 심의(라운드 토론) LLM 튜닝 — 환경별 최적화 손잡이 ------------------------------
# 절단 층위 설계: 모델 입력(role 등)은 무절단 기본, RA 기록은 온전한 발언(여유 상한 2000자),
# 화면 버블만 절단(CLIP_SCALE 배율). 코드 기본값이 이미 이 설계라 이 키들이 없으면 그대로 동작.
# 아래 값은 cae00(상암 GLM) 권장 리터럴 — dev 박스에는 이 킷을 적용하지 말 것(dev 는
# temperature·effort 를 A/B 후 대상 .env 에 직접 결정, 컨텍스트 방어는 DELIB_ROLE_CLIP=1200 등).
# 배포 절차 주의(2건):
#   ① apply-envs.sh 기본 서비스 목록에 agent-server 가 없다 — 반드시 인자 명시:
#      bash infra/env-kits/apply-envs.sh agent-server   (적용 후 agent-server 재시작)
#   ② 이 킷은 '없는 키만 추가' 계약이라 초기 시드 전용 — 이후 튜닝 변경(값 수정)은 킷이 아니라
#      대상 <HWAXAgentServer>/.env 를 직접 고쳐야 반영된다.
# 주의: DELIB_MAX_TOKENS 는 설정 시 8192급 여유값만 — 2048~4096은 thinking 토큰과 겹치면
#       미완 JSON 절단→폴백을 유발해 오히려 악화된다(GLM 심의 품질 검증 보고서 §5-2).
DELIB_TEMPERATURE=0.7
DELIB_CLIP_SCALE=1.5
DELIB_PARSE_RETRIES=2
DELIB_TIMEOUT_S=180
# DELIB_REASONING_EFFORT=high   # ← 상암 vLLM 의 reasoning parser(glm45) 설정을 raw curl 로
#   선확인한 뒤 주석 해제 — parser 미스매치 상태에서 켜면 <think> 가 본문에 섞여 JSON 파싱
#   실패율이 올라 오히려 발언이 짧아진다(진단 절차: 검증 보고서 §4 1단계).
# ReAct 챗 경로(도구호출)는 결정성 유지를 위해 LLM_TEMPERATURE 미설정(=0) 권장.
# 챗 경로 타임아웃을 조절하려면 LLM_TIMEOUT_S(전역, 챗 포함 — 기본 라이브러리 600s) 를 쓰되,
# GLM nostream 모드는 전체 생성이 read timeout 안에 끝나야 하므로 하향에 신중할 것.

# --- 깊이 회복 손잡이(GLM 리뷰 §5 검증 통과분) — 기본 전부 꺼짐(무회귀) --------------
# ⚠ 동시 적용 금지 — GLM급은 다중 제약에서 지시 추종이 분산돼 기법 적층이 상쇄된다(§5).
#   한 번에 하나씩 켜고 A/B(러너북 §5 지표: 발언당 수치 인용·반박 인용률·파싱 실패율) 후
#   유지/철회를 결정할 것. 권장 실험 순서 = 아래 나열 순서(T1→T2→T3→…).
# DELIB_EVIDENCE_PREPASS=1   # T1 정량 근거 선주입 — 심의 전 지식·보고서 검색(hybrid_search 등
#   결정적 4콜)→LLM 증류→[정량 근거] 블록 주입. 수치 인용을 '기억 인출'→'컨텍스트 발췌'로
#   바꾸는 최대 레버. 도구 미가용 시 자동 스킵(best-effort).
# DELIB_REBUT_QUOTE=1        # T2 반박 인용 계약 — rebut 을 {target,quote,counter,basis} 객체로
#   강제하고 quote 실재를 코드 검증(불일치 시 재시도 힌트). 허수아비 반박 구조 차단.
#   DELIB_PARSE_RETRIES=2 이상과 함께 쓸 것(신규 스키마 1차 준수율 대비).
# DELIB_PROSE_FIRST=1        # T3 산문 논증 후 JSON — 형식 강제가 깎던 추론 회수. 단 상암
#   thinking 이 이미 활성이면(러너북 §4 진단) 효과 중복이라 켜지 말 것. 출력 토큰 1.5~2배.
# DELIB_CROSS_EXAM=1         # 2R 교차심문 — 지목 표적의 원본 전체에 반박(라운드로빈). 넓고
#   얕은 일반론 반박 도피로 차단. 비용 중립(프롬프트는 오히려 축소).
# DELIB_ANCHOR=1             # 3R 입장 앵커 재주입 — 수렴 라운드 동조 붕괴 방어. 라운드 수를
#   늘리는 실험보다 반드시 선행할 것.
# DELIB_CHAIR_BESTOF=3       # 의장 결정문 후보 n개→심판 선택(1=끔). temp>0 필요(0이면 후보
#   동일해 무의미). 의장 1곳 한정이라 +2~3콜로 저렴.
# DELIB_CHAIR_CITE=1         # 의장 결정문에 [R2·페르소나키] 출처 태깅 — 근거 없는 항목은
#   [무근거] 표기. 절충형 뭉개기 가시화(가장 저렴한 손잡이).
