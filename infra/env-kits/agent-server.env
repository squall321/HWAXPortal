# HWAXAgentServer vLLM 주소 .env 블록 — 대상: <HWAXAgentServer>/.env (없는 키만 추가됨)
# vLLM 주소는 박스별로 다르다(playbook §8) — 아래 값은 플레이스홀더, 박스별 실제 값으로 채운다.
# cae00 테스트: VLLM_BASE_URL=http://192.168.1.100:8000/v1, VLLM_MODEL=qwen2.5-7b-dev (dev 박스 vLLM).
#              상암 프로덕션 LLM 이 서면 그 주소로 교체.
VLLM_BASE_URL=http://<vllm-host>:8000/v1
VLLM_MODEL=<served-model>
