# HWAX nginx — generated from this template by infra/scripts/gen-nginx-conf.sh.
# DO NOT edit hwax.conf directly (it is overwritten). Edit this template or routes.env.
# Rootless-safe: pid/logs/temp all under /tmp (the only guaranteed-writable dir).

worker_processes auto;
pid /tmp/hwax-nginx.pid;
error_log /tmp/hwax-nginx-error.log warn;

events { worker_connections 1024; }

http {
    include /etc/nginx/mime.types;
    default_type application/octet-stream;
    access_log off;
    sendfile on;
    server_tokens off;

    client_body_temp_path /tmp/hwax-nginx-body;
    proxy_temp_path       /tmp/hwax-nginx-proxy;
    fastcgi_temp_path     /tmp/hwax-nginx-fastcgi;
    uwsgi_temp_path       /tmp/hwax-nginx-uwsgi;
    scgi_temp_path        /tmp/hwax-nginx-scgi;

    gzip on;
    gzip_types text/plain text/css application/javascript application/json image/svg+xml;
    gzip_min_length 1024;

    # WebSocket upgrade passthrough (vite HMR / streamlit / etc. on linked services)
    map $http_upgrade $connection_upgrade { default upgrade; '' close; }

    proxy_http_version 1.1;
    proxy_set_header Host              $host;
    proxy_set_header X-Real-IP         $remote_addr;
    proxy_set_header X-Forwarded-For   $proxy_add_x_forwarded_for;
    proxy_set_header X-Forwarded-Proto $scheme;
    # Original host INCLUDING port ($http_host, unlike $host) — prefix-aware backends (HEAXHub
    # _public_base_url) read this first to rebuild public absolute URLs; without it they fall back
    # to Host/upstream and emit http://localhost:<port> links that break behind the TLS entry.
    proxy_set_header X-Forwarded-Host  $http_host;
    proxy_set_header Upgrade           $http_upgrade;
    proxy_set_header Connection        $connection_upgrade;

    # Plain HTTP (health / LAN). When TLS is on, the HTTPS server below is the main entry.
    server {
        listen {{HTTP_PORT}};
        server_name _;

        add_header X-Content-Type-Options "nosniff" always;
        add_header Referrer-Policy "strict-origin-when-cross-origin" always;

        # ── per-system path routes (generated from routes.env) ──
{{LOCATIONS}}
        # ── MCP chat SSE: the portal's only streaming endpoint ──
        # Without these, the long-lived text/event-stream gets buffered/cut: the global
        # `gzip on` chunk-buffers it, proxy_buffering(on) holds the whole body, and the
        # default proxy_read_timeout(60s) drops a quiet stream. Scoped to /agent/ so nothing
        # else changes. X-Accel-Buffering:no is also set per-response by the backend.
        location /agent/ {
            proxy_pass http://127.0.0.1:{{PORTAL_PORT}};
            proxy_buffering off;
            proxy_cache off;
            gzip off;
            proxy_read_timeout 1h;
            proxy_connect_timeout 300s;
        }
        # ── MCP gateway (streamable-http) — a personal Claude connects here with a portal PAT.
        # STRIPs /mcp-gw/ → gateway sees /mcp (which authenticates the Bearer PAT itself). Same
        # no-buffer/long-timeout streaming settings as /agent/. Keep in sync with the TLS server
        # block in gen-nginx-conf.sh.
        location /mcp-gw/ {
            proxy_pass http://127.0.0.1:9110/;
            proxy_buffering off;
            proxy_cache off;
            gzip off;
            proxy_read_timeout 1h;
            proxy_connect_timeout 300s;
        }
        # ── portal (hero + API): catch-all ──
        location / {
            proxy_pass http://127.0.0.1:{{PORTAL_PORT}};
        }
    }
{{TLS_SERVER}}
}
