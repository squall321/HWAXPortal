# ─────────────────────────────────────────────────────────────────────────────
# HWAX Portal — infra (Apptainer) config.   cp infra/.env.example infra/.env
# Used by infra/scripts/* to run the portal + nginx as rootless Apptainer instances.
# Separate from backend/.env (that is the app's own config).
# ─────────────────────────────────────────────────────────────────────────────

APP_ENV=prod

# nginx listen port. Default 8088 (uncommon to dodge collisions) — rootless containers can't bind <1024.
# Front it with the server's real :80/:443 (corp LB / system reverse proxy / iptables,
# or raise net.ipv4.ip_unprivileged_port_start). Set to 80 only if your host allows it.
HTTP_PORT=8088

# Portal backend bind port (host network); nginx proxies "/" to it.
PORTAL_PORT=8723

# ── TLS / HTTPS (terminate at the portal nginx) ──────────────────────────────
# Turn on to also listen on HTTPS_PORT with TLS. Cert is self-signed by gen-tls-cert.sh
# until you drop the corp-issued cert at the same paths. Rootless :443 needs a one-time
# `sudo ./infra/scripts/grant-net-bind.sh` (sysctl ip_unprivileged_port_start=443).
ENABLE_TLS=false
HTTPS_PORT=443
TLS_SERVER_NAME=hwax.sec.samsung.net
TLS_CERT_PATH=infra/tls/hwax.crt
TLS_KEY_PATH=infra/tls/hwax.key

# The origin BROWSERS reach the portal at = nginx. In prod this is the real domain.
# Must match how users hit it so cookies + SAML Destination line up.
PUBLIC_BASE_URL=http://localhost:8088
COOKIE_SECURE=false      # true for an https domain

# Auth: mock until Samsung AD SSO is provisioned (flip to saml + drop AD metadata — GO-LIVE.md)
AUTH_PROVIDER=mock
MOCK_USER_EMAIL=hwax.demo@samsung.com
MOCK_USER_NAME="HWAX Demo User"
MOCK_USER_GROUPS=portal-admin

# ⚠️ set a real value for prod:  openssl rand -hex 32
SESSION_SECRET=change-me-infra-dev

# Routing file (dev: config/routes.env, prod: config/routes.prod.env). Relative to backend/.
ROUTES_PATH=config/routes.env

# Corporate egress proxy for image pulls (apptainer build → docker hub). Same as MXWP.
HWAX_FALLBACK_PROXY=http://168.219.61.252:8080

# ── Image sync via Google Drive (rclone) ────────────────────────────────────
# Build the .sif ONCE on a machine that can reach Docker Hub, push to Drive, then pull on
# every other server — so a rate-limited/air-gapped host never builds from Docker Hub.
#   build host:  ./infra/scripts/images-to-drive.sh
#   any server:  ./infra/scripts/images-from-drive.sh  →  ./infra/scripts/start.sh
# Configure rclone once (rclone config → drive), then set the remote+path below.
# HWAX_DRIVE_REMOTE=ApptainerImages:HWAXPortal/images
HWAX_DRIVE_REMOTE=
HWAX_DRIVE_RETAIN=3      # keep last N timestamped image sets on Drive (0 = keep all)
# Optional: your own Google OAuth app for rclone (else rclone's built-in default client is used).
# These live here (gitignored), NOT in the scripts. Leave blank to use the default.
# HWAX_GDRIVE_CLIENT_ID=
# HWAX_GDRIVE_CLIENT_SECRET=

# Apptainer binary. Leave UNSET so the scripts auto-pick the locally-extracted
# infra/apptainer/bin-<ver>/usr/bin/apptainer (no-sudo install), falling back to PATH.
# Only set this to pin a specific binary.
# APPTAINER=/usr/bin/apptainer
